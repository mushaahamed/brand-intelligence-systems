{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "P07 Reputation Research Output",
  "type": "object",
  "required": ["overall_reputation_score","brand_community_strength","reputation_watchout"],
  "properties": {
    "overall_reputation_score":   { "type": "number", "minimum": 1, "maximum": 5 },
    "reddit_key_themes":          { "type": "array", "items": { "type": "string" } },
    "common_customer_complaints": { "type": "array", "items": { "type": "string" } },
    "common_customer_praise":     { "type": "array", "items": { "type": "string" } },
    "brand_community_strength":   { "type": "string", "enum": ["STRONG","MODERATE","WEAK","NONE"] },
    "viral_moments":              { "type": "array", "items": { "type": "string" } },
    "influencer_sentiment":       { "type": "string", "enum": ["POSITIVE","NEUTRAL","MIXED","NEGATIVE","UNKNOWN"] },
    "reputation_watchout":        { "type": "string" },
    "reputation_opportunity":     { "type": ["string","null"] }
  }
}
