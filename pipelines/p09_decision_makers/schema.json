{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "P09 Decision Makers Output",
  "type": "object",
  "required": ["buying_committee","primary_contact"],
  "properties": {
    "buying_committee": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name","title","role_type","decision_relevance_score","outreach_priority","personalisation_hook"],
        "properties": {
          "name":                      { "type": "string" },
          "title":                     { "type": "string" },
          "linkedin_url":              { "type": ["string","null"] },
          "role_type":                 { "type": "string", "enum": ["ECONOMIC_BUYER","INITIATOR","EVENTS_SPECIALIST","INFLUENCER"] },
          "decision_relevance_score":  { "type": "integer", "minimum": 1, "maximum": 5 },
          "outreach_priority":         { "type": "string", "enum": ["HIGH","MEDIUM","LOW"] },
          "personalisation_hook":      { "type": "string" },
          "years_at_company":          { "type": ["string","null"] },
          "previous_company":          { "type": ["string","null"] }
        }
      }
    },
    "primary_contact":                { "type": "string" },
    "buying_committee_size_estimate": { "type": ["integer","null"] },
    "notes":                          { "type": ["string","null"] }
  }
}
