# ─── APIFY ────────────────────────────────────────────────────────────────────
# Use 3-5 accounts and assign each to a specific pipeline group
# Account rotation prevents credit exhaustion and rate limits
APIFY_TOKEN_1=apify_api_YOUR_TOKEN_1        # Company overview + Brand identity
APIFY_TOKEN_2=apify_api_YOUR_TOKEN_2        # Market position + Competitor mapping
APIFY_TOKEN_3=apify_api_YOUR_TOKEN_3        # Brand activity + Experiential footprint
APIFY_TOKEN_4=apify_api_YOUR_TOKEN_4        # Reputation research + Watchouts
APIFY_TOKEN_5=apify_api_YOUR_TOKEN_5        # Decision makers + Contact intelligence

# ─── ANTHROPIC ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ─── HUNTER.IO ────────────────────────────────────────────────────────────────
HUNTER_API_KEY=YOUR_HUNTER_KEY_HERE

# ─── APP SETTINGS ─────────────────────────────────────────────────────────────
APP_ENV=development                   # development | production
LOG_LEVEL=INFO
OUTPUT_DIR=./outputs
MAX_RETRIES=3
REQUEST_TIMEOUT=30
RATE_LIMIT_DELAY=2                    # seconds between Apify calls

# ─── API SERVER ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
